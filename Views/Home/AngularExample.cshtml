@{
    ViewData["Title"] = "AngularJS Example";
}

<div ng-app="angularCoreDemo" ng-controller="ProductController as vm" class="mt-4">
    <h1 class="display-6">AngularJS Core Example</h1>
    <p class="text-muted">Simple two-way binding and list filtering using AngularJS.</p>

    <div class="mb-3">
        <label for="searchText" class="form-label">Filter products</label>
        <input id="searchText"
               type="text"
               class="form-control"
               placeholder="Type to filter..."
               ng-model="vm.searchText" />
    </div>

    <div class="mb-3">
        <label for="newProduct" class="form-label">Add product</label>
        <div class="input-group">
            <input id="newProduct"
                   type="text"
                   class="form-control"
                   placeholder="Product name"
                   ng-model="vm.newProductName"
                   ng-keyup="$event.keyCode === 13 && vm.addProduct()" />
            <button type="button" class="btn btn-primary" ng-click="vm.addProduct()">Add</button>
        </div>
    </div>

    <ul class="list-group">
        <li class="list-group-item d-flex justify-content-between align-items-center"
            ng-repeat="product in vm.products | filter:vm.searchText track by $index">
            <span>{{ product.name }}</span>
            <span class="badge text-bg-secondary">{{ product.price | currency }}</span>
        </li>
    </ul>

    <p class="mt-3 mb-0">Total products: <strong>{{ vm.products.length }}</strong></p>
</div>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.3/angular.min.js"></script>
    <script>
        (function () {
            "use strict";

            angular
                .module("angularCoreDemo", [])
                .controller("ProductController", function () {
                    var vm = this;

                    vm.searchText = "";
                    vm.newProductName = "";
                    vm.products = [
                        { name: "Laptop", price: 1200 },
                        { name: "Phone", price: 800 },
                        { name: "Headphones", price: 200 }
                    ];

                    vm.addProduct = function () {
                        if (!vm.newProductName || !vm.newProductName.trim()) {
                            return;
                        }

                        vm.products.push({
                            name: vm.newProductName.trim(),
                            price: 100
                        });
                        vm.newProductName = "";
                    };
                });
        })();
    </script>
}
