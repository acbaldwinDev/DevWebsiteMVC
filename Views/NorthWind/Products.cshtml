@model IReadOnlyList<DevWebsiteMVC.Models.NorthWind.Product>
@{
    ViewData["Title"] = "NorthWind Products";
}

<div class="mt-4">
    <h1 class="display-6">NorthWind Products</h1>
    <p class="text-muted">Sample Entity Framework query against SQL Server NorthWind.</p>

    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Product</th>
                    <th scope="col">Category ID</th>
                    <th scope="col">Unit Price</th>
                    <th scope="col">In Stock</th>
                    <th scope="col">Discontinued</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.ProductID</td>
                        <td>@product.ProductName</td>
                        <td>@(product.CategoryID?.ToString() ?? "-")</td>
                        <td>@(product.UnitPrice.HasValue ? product.UnitPrice.Value.ToString("C") : "-")</td>
                        <td>@(product.UnitsInStock?.ToString() ?? "-")</td>
                        <td>@(product.Discontinued ? "Yes" : "No")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
